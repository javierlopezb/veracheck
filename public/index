<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VeraCheck — Prototipo académico</title>
<link rel="stylesheet" href="style.css">
</head>
<body>

  <div class="stage">
    <div class="phone" id="phone">

      <!-- Barra de video simulada -->
      <div class="video-layer" id="videoLayer">
        <div class="video-fallback" id="videoFallback" aria-hidden="true">
          <span class="glow glow-a"></span>
          <span class="glow glow-b"></span>
          <div class="silhouette"></div>
        </div>
        <video class="video-real" id="localVideo" autoplay muted loop playsinline hidden></video>
        <div class="video-scrim"></div>
      </div>

      <!-- Barra superior tipo feed -->
      <div class="feed-topbar">
        <span class="feed-tab">Siguiendo</span>
        <span class="feed-tab feed-tab--active">Para ti</span>
        <span class="feed-tab">En vivo</span>
      </div>

      <span class="demo-flag">Demostración académica</span>

      <!-- Capsula de análisis en curso -->
      <div class="vera-capsule" id="veraCapsule" hidden role="status" aria-live="polite">
        <span class="vera-ring" aria-hidden="true"></span>
        <div class="vera-capsule-copy">
          <p class="vera-capsule-title">VeraCheck</p>
          <p class="vera-capsule-step" id="capsuleStep">Iniciando análisis…</p>
          <div class="vera-progress-track" aria-hidden="true">
            <div class="vera-progress-fill" id="capsuleProgress"></div>
          </div>
        </div>
      </div>

      <!-- Etiqueta de resultado final -->
      <button class="vera-tag" id="veraTag" type="button" data-verdict="warning" hidden>
        <span class="vera-tag-icon" id="veraTagIcon" aria-hidden="true"></span>
        <span class="vera-tag-copy">
          <strong id="veraTagLabel">En duda</strong>
          <span id="veraTagHint">Toca para ver el análisis</span>
        </span>
      </button>

      <!-- Acciones laterales tipo feed -->
      <aside class="feed-actions" aria-label="Acciones del video">
        <button class="feed-action" type="button" aria-label="Me gusta">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none"><path d="M12 20.5s-7.5-4.6-9.8-9.2C.9 8 2.3 4.8 5.6 4.1c2-.4 3.9.5 4.9 2.1a5.4 5.4 0 0 1 3-2.2c3.3-.7 5.6 2.6 4.4 5.5C15.9 15.7 12 20.5 12 20.5Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg>
          <span>128K</span>
        </button>
        <button class="feed-action" type="button" aria-label="Comentarios">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none"><path d="M4 5h16v11H9l-4 3.5V16H4V5Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg>
          <span>2,431</span>
        </button>
        <button class="feed-action" type="button" aria-label="Compartir">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none"><path d="M4 12 20 5l-4 15-5-6-7-2Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg>
          <span>Compartir</span>
        </button>
      </aside>

      <!-- Metadatos del video -->
      <div class="feed-meta">
        <p class="feed-creator" id="feedCreator">@alerta_peru_hoy</p>
        <p class="feed-caption" id="feedCaption">Atención: supuesto cambio electoral que está generando reacciones.</p>
        <p class="feed-hashtags" id="feedHashtags">#Política #Perú #Actualidad</p>
      </div>
    </div>

    <!-- Panel de modo demostración -->
    <div class="demo-panel">
      <button class="demo-toggle" id="demoModeBtn" type="button" aria-expanded="false" aria-controls="demoSelector">
        <svg viewBox="0 0 24 24" width="15" height="15" fill="none"><path d="M4 6h16M4 12h16M4 18h10" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
        Modo demostración
      </button>

      <div class="demo-selector" id="demoSelector" hidden>
        <p class="demo-selector-label">Elegir caso de demostración</p>

        <button class="demo-case" type="button" data-case="politica">
          <span class="demo-dot demo-dot--false" aria-hidden="true"></span>
          <span><strong>Política</strong> · Posiblemente falso</span>
        </button>
        <button class="demo-case" type="button" data-case="salud">
          <span class="demo-dot demo-dot--warning" aria-hidden="true"></span>
          <span><strong>Salud</strong> · En duda</span>
        </button>
        <button class="demo-case" type="button" data-case="social">
          <span class="demo-dot demo-dot--verified" aria-hidden="true"></span>
          <span><strong>Social</strong> · Verificado</span>
        </button>

        <div class="local-demo">
          <input class="local-input" id="localVideoInput" type="file" accept="video/mp4,video/webm,video/quicktime,.mp4,.webm,.mov" hidden>
          <button class="demo-case demo-case--local" id="localLoadBtn" type="button">
            <span class="demo-dot demo-dot--local" aria-hidden="true"></span>
            <span><strong>Cargar video local</strong></span>
          </button>

          <div class="local-card" id="localCard" hidden>
            <p class="local-card-title" id="localFileName">Ningún archivo cargado</p>

            <label class="local-field-label" for="localClaimInput">Escribe la afirmación principal detectada en el video</label>
            <textarea class="local-claim" id="localClaimInput" rows="3" placeholder="Ejemplo: este producto elimina virus en segundos"></textarea>

            <label class="local-field-label" for="localVerdictSelect">Resultado de la demostración</label>
            <select class="local-select" id="localVerdictSelect">
              <option value="verified">Verificado</option>
              <option value="warning" selected>En duda</option>
              <option value="false">Posiblemente falso</option>
            </select>

            <p class="local-disclaimer">Resultado configurado para demostración académica.</p>

            <div class="local-actions">
              <button class="local-btn" id="analyzeLocalBtn" type="button">Analizar video cargado</button>
              <button class="local-btn local-btn--ghost" id="resetLocalBtn" type="button">Restablecer video de demostración</button>
            </div>

            <div class="ai-analysis-block">
              <p class="ai-analysis-label">Análisis con inteligencia artificial</p>
              <p class="ai-analysis-copy">Sube el video al backend, extrae afirmaciones con IA y las contrasta con verificaciones publicadas reales.</p>
              <button class="local-btn local-btn--ai" id="analyzeAiBtn" type="button">Analizar video con IA</button>
              <p class="ai-status" id="aiStatus" hidden></p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <footer class="app-footer">
      <p>Prototipo académico: simula una posible integración nativa. No reemplaza la verificación humana.</p>
    </footer>
  </div>

  <!-- Panel de detalles -->
  <div class="overlay" id="overlay" hidden></div>
  <section class="details-panel" id="detailsPanel" role="dialog" aria-modal="true" aria-label="Detalles de la verificación" hidden>
    <div class="details-handle" aria-hidden="true"></div>
    <header class="details-header">
      <span class="verdict-chip" id="verdictChip" data-verdict="false">Posiblemente falso</span>
      <button class="details-close" id="detailsCloseBtn" type="button" aria-label="Cerrar panel">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none"><path d="M6 6l12 12M18 6 6 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
      </button>
    </header>

    <div class="details-body">
      <div class="confidence-row">
        <div class="confidence-ring" id="confidenceRing" style="--pct:91">
          <span class="confidence-value" id="confidenceValue">91%</span>
        </div>
        <div class="confidence-copy">
          <p class="confidence-label">Nivel de confianza</p>
          <p class="confidence-sub">Estimación simulada para fines de demostración.</p>
        </div>
      </div>

      <div class="detail-block">
        <p class="detail-label">Afirmación detectada</p>
        <p class="detail-text" id="claimText">—</p>
      </div>

      <div class="detail-block detail-block--split">
        <div>
          <p class="detail-label">Categoría</p>
          <p class="detail-text" id="categoryText">—</p>
        </div>
        <div>
          <p class="detail-label">Caso</p>
          <p class="detail-text" id="titleText">—</p>
        </div>
      </div>

      <div class="detail-block">
        <p class="detail-label">Explicación</p>
        <p class="detail-text" id="explanationText">—</p>
      </div>

      <div class="detail-block" id="demoConfigBlock" hidden>
        <p class="detail-label">Demostración académica</p>
        <p class="detail-text">Resultado configurado para demostración académica.</p>
      </div>

      <!-- Bloques del modo simulado (casos predefinidos y modo manual) -->
      <div id="simulatedBlocks">
        <div class="detail-block">
          <p class="detail-label">Fuentes simuladas consultadas</p>
          <ul class="sources-list" id="sourcesList"></ul>
        </div>

        <p class="advisory-note">Todas las señales y fuentes de esta demostración son simuladas. VeraCheck no ejecuta STT, OCR ni contraste real con fuentes.</p>

        <div class="detail-block">
          <p class="detail-label">Señales analizadas (simuladas)</p>
          <ul class="signals-list">
            <li class="signal-item">
              <span class="signal-icon" aria-hidden="true">STT</span>
              <div><p class="signal-title">Voz a texto</p><p class="signal-text" id="signalStt">—</p></div>
            </li>
            <li class="signal-item">
              <span class="signal-icon" aria-hidden="true">OCR</span>
              <div><p class="signal-title">Texto en pantalla</p><p class="signal-text" id="signalOcr">—</p></div>
            </li>
            <li class="signal-item">
              <span class="signal-icon" aria-hidden="true">META</span>
              <div><p class="signal-title">Metadatos</p><p class="signal-text" id="signalMeta">—</p></div>
            </li>
            <li class="signal-item">
              <span class="signal-icon" aria-hidden="true">SEM</span>
              <div><p class="signal-title">Comparación semántica</p><p class="signal-text" id="signalSemantic">—</p></div>
            </li>
            <li class="signal-item">
              <span class="signal-icon" aria-hidden="true">DFK</span>
              <div><p class="signal-title">Riesgo de deepfake</p><p class="signal-text" id="signalDeepfake">—</p></div>
            </li>
          </ul>
        </div>
      </div>

      <!-- Bloques del modo de análisis real con IA -->
      <div id="realBlocks" hidden>
        <div class="detail-block">
          <p class="detail-label">Transcripción / resumen de audio</p>
          <p class="detail-text" id="realTranscript">—</p>
        </div>

        <div class="detail-block">
          <p class="detail-label">Texto detectado en pantalla</p>
          <ul class="sources-list" id="realOnscreenList"></ul>
        </div>

        <div class="detail-block">
          <p class="detail-label">Afirmaciones detectadas y verificaciones publicadas</p>
          <ul class="claims-list" id="realClaimsList"></ul>
        </div>

        <div class="detail-block">
          <p class="detail-label">Nota sobre manipulación</p>
          <p class="detail-text" id="realManipulationNote">—</p>
        </div>

        <ul class="advisory-list">
          <li>El análisis identifica afirmaciones; no certifica la veracidad total del video.</li>
          <li>La detección de deepfakes no es concluyente en esta versión.</li>
          <li>Resultado orientativo basado en IA y verificaciones publicadas. No reemplaza la revisión humana.</li>
        </ul>
      </div>
    </div>
  </section>

  <script src="script.js"></script>
</body>
</html>
